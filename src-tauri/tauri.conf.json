{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TPMCluely",
  "version": "0.1.0",
  "identifier": "com.cluely.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TPMCluely",
        "width": 1440,
        "height": 960,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "hardenedRuntime": true
    }
  }
}
