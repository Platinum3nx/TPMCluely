{
  "name": "cluely-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "ticket-generator"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "clean:desktop": "rm -rf dist node_modules/.vite-temp src-tauri/target",
    "lint": "eslint src eslint.config.js vite.config.ts playwright.config.ts",
    "test:web": "VITE_ENABLE_BROWSER_MOCK=true node ./scripts/run-vitest-sequential.mjs",
    "test:e2e": "VITE_ENABLE_BROWSER_MOCK=true playwright test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "verify:desktop": "npm run clean:desktop && npm run build && npm run test:web && cargo test --manifest-path src-tauri/Cargo.toml && npm run tauri:build -- --debug --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.54.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.0.0",
    "vitest": "^3.1.1"
  }
}
