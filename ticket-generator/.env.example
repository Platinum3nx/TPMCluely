# Required: Gemini ticket generation
GEMINI_API_KEY=

# Required: Linear issue creation
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Optional: restrict accepted browser origins for POST requests
# Example: ALLOWED_ORIGINS=https://your-app.com,https://staging.your-app.com
ALLOWED_ORIGINS=

# Optional: protect the entire app/API with HTTP Basic Auth in deployed environments
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
